# Django Settings
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database — PostgreSQL connection string
# Leave empty / unset to use the default local PostgreSQL config in settings.py
# DATABASE_URL=postgresql://user:password@localhost:5432/medroster_db

# For Render deployment:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# ALLOWED_HOSTS=medroster-backend.onrender.com
# CORS_ALLOWED_ORIGINS=https://medroster-frontend.onrender.com
# DEBUG=False
# SECRET_KEY=<generate-a-strong-random-key>
